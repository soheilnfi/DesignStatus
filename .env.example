# ---- Server ----
PORT=3000
# Public base URL where THIS backend is reachable (Vercel/Render URL, no trailing slash)
APP_URL=https://your-backend.example.com

# ---- Database (Postgres) ----
# Free option: https://neon.tech or https://supabase.com
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ---- Figma OAuth App ----
# Create at https://www.figma.com/developers/apps
FIGMA_CLIENT_ID=your_figma_client_id
FIGMA_CLIENT_SECRET=your_figma_client_secret
# Must exactly match the "Redirect URI" configured in the Figma OAuth app
FIGMA_REDIRECT_URI=https://your-backend.example.com/auth/figma/callback
# current_user:read is enough — we only ever call GET /v1/me to read id+email
FIGMA_OAUTH_SCOPE=current_user:read

# ---- Auth tokens issued to the widget ----
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=30d

# ---- Direct crypto payment (USDT-TRC20, no third-party gateway) ----
# Your own wallet address that receives subscription payments. Each pending
# payment gets a unique 6-decimal amount (e.g. 5.000123) added on top of
# SUBSCRIPTION_PRICE_USD so concurrent payers to this same address can be
# told apart; the backend confirms a payment by polling TronGrid (a public
# Tron block explorer API) for a matching incoming USDT transfer.
USDT_WALLET_ADDRESS=your_trc20_wallet_address
SUBSCRIPTION_PRICE_USD=5

FREE_USES=20
SUBSCRIPTION_DAYS=30

# ---- Admin bypass ----
# Comma-separated Figma account email(s) that always get unlimited access
# (skips the free-use limit and payment entirely). Meant for the widget's
# own developer/owner account. Leave empty/unset to disable.
ADMIN_EMAILS=your_figma_account_email@example.com
