# ---- Server ----
PORT=3000
# Public base URL where THIS backend is reachable (Render/Vercel URL, no trailing slash)
APP_URL=https://your-backend.onrender.com

# ---- Database (Postgres) ----
# Free option: https://neon.tech or https://supabase.com
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ---- Figma OAuth App ----
# Create at https://www.figma.com/developers/apps
FIGMA_CLIENT_ID=your_figma_client_id
FIGMA_CLIENT_SECRET=your_figma_client_secret
# Must exactly match the "Redirect URI" configured in the Figma OAuth app
FIGMA_REDIRECT_URI=https://your-backend.onrender.com/auth/figma/callback
# current_user:read is enough — we only ever call GET /v1/me to read id+email
FIGMA_OAUTH_SCOPE=current_user:read

# ---- Auth tokens issued to the plugin ----
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=30d

# ---- NOWPayments (crypto payment gateway) ----
# Create account at https://nowpayments.io, get API key from dashboard
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
# Set this same secret in NOWPayments dashboard -> Store Settings -> IPN secret key
NOWPAYMENTS_IPN_SECRET=your_ipn_secret
NOWPAYMENTS_PAY_CURRENCY=usdttrc20
SUBSCRIPTION_PRICE_USD=5

FREE_USES=3
SUBSCRIPTION_DAYS=30
